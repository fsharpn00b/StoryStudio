{
  "private": true,
  "scripts": {
    "start": "dotnet tool restore && dotnet fable watch src --runFast vite",
    "build": "dotnet tool restore && dotnet fable src --run vite build",
    "clean": "dotnet fable clean src --yes",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test:engine": "dotnet test tests/StoryStudio.EngineTests/StoryStudio.EngineTests.fsproj",
    "test:e2e": "npm exec playwright test",
    "test:e2e:ui": "npm exec playwright test --ui",
    "test:rc": "npm run test:engine && npm run test:e2e -- --reporter=list",
    "test": "npm run test:engine && npm run test:e2e"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "ohm-js": "^17.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "use-sync-external-store": "^1.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^3.1.0",
    "typescript": "^5.9.3",
    "vite": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
